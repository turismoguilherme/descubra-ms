# Porta HTTP (webhooks + health)
PORT=3333

# Mesmo secret configurado no Supabase como DESCUBRA_WEBHOOK_SECRET
DESCUBRA_WEBHOOK_SECRET=seu-secret-aqui

# Supabase — para chamar guata-web-rag (mesmo projeto do Descubra MS)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
# Opcional: mesmo valor de DESCUBRA_WEBHOOK_SECRET (auth interna do bot no guata-web-rag)
GUATA_BOT_INTERNAL_SECRET=seu-secret-aqui

# Grupo WhatsApp para divulgar eventos publicados (opcional)
# Formato: 120363XXXX@g.us — deixe vazio para não postar em grupo
WHATSAPP_BROADCAST_GROUP_ID=
